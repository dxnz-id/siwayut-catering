function getOption(array $args, string $name, string $default = ''): string {
    foreach ($args as $arg) {
        if (str_starts_with($arg, "--{$name}=")) {
            return substr($arg, strlen("--{$name}="));
        }
    }
    return $default;
}

function hasFlag(array $args, string $name): bool {
    return in_array("--{$name}", $args, true);
}

function getArgument(array $args, int $index, string $default = ''): string {
    // Filter out --options
    $positional = array_values(array_filter($args, fn($a) => !str_starts_with($a, '--')));
    return $positional[$index] ?? $default;
}

