// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: db:create
// ─────────────────────────────────────────────────────────────────────────────
function cmd_db_create(array $args): void {
    $dbName = $_ENV['DB_DATABASE'] ?? '';
    if ($dbName === '') {
        error('DB_DATABASE is not set in .env');
        return;
    }

    $driver   = $_ENV['DB_DRIVER']   ?? 'mysql';
    $host     = $_ENV['DB_HOST']     ?? '127.0.0.1';
    $port     = $_ENV['DB_PORT']     ?? '3306';
    $username = $_ENV['DB_USERNAME'] ?? 'root';
    $password = $_ENV['DB_PASSWORD'] ?? '';

    try {
        $dsn = "{$driver}:host={$host};port={$port}";
        $pdo = new PDO($dsn, $username, $password, [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
        ]);
        $pdo->exec("CREATE DATABASE IF NOT EXISTS `{$dbName}` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci");
        success("Database '{$dbName}' created successfully.");
    } catch (PDOException $e) {
        error("Failed to create database: " . $e->getMessage());
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Migration Helpers
// ─────────────────────────────────────────────────────────────────────────────
function ensureMigrationsTable(PDO $db): void {
    $db->exec("CREATE TABLE IF NOT EXISTS `migrations` (
        `id` INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
        `migration` VARCHAR(255) NOT NULL,
        `batch` INT NOT NULL,
        `executed_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4");
}

function getExecutedMigrations(PDO $db): array {
    $stmt = $db->query("SELECT `migration` FROM `migrations` ORDER BY `id`");
    return $stmt->fetchAll(PDO::FETCH_COLUMN);
}

function getMigrationFiles(): array {
    $path = BASE_PATH . '/database/migrations';
    if (!is_dir($path)) {
        return [];
    }
    $files = glob($path . '/*.php');
    sort($files);
    return $files;
}

function migrationFileToClass(string $path): string {
    $name = pathinfo($path, PATHINFO_FILENAME);
    $parts = explode('_', $name, 2);
    $className = str_replace(' ', '', ucwords(str_replace('_', ' ', $parts[1] ?? $parts[0])));
    return 'Database\\Migrations\\' . $className;
}

function runPhpMigration(PDO $db, string $file, string $name): void {
    require $file;
    $class = migrationFileToClass($file);
    $migration = new $class();

    $sql = $migration->up();
    $statements = is_array($sql) ? $sql : [$sql];
    foreach ($statements as $statement) {
        $statement = trim($statement);
        if ($statement !== '') {
            $db->exec($statement);
        }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: migrate
// ─────────────────────────────────────────────────────────────────────────────
function cmd_migrate(array $args): void {
    $db = resolveDb();
    if (!$db) {
        return;
    }

    ensureMigrationsTable($db);
    $executed = getExecutedMigrations($db);
    $files = getMigrationFiles();

    $stmt = $db->query("SELECT COALESCE(MAX(`batch`), 0) FROM `migrations`");
    $batch = (int) $stmt->fetchColumn() + 1;

    $ran = 0;
    foreach ($files as $file) {
        $name = pathinfo($file, PATHINFO_FILENAME);
        if (in_array($name, $executed, true)) {
            continue;
        }

        info("Migrating: " . color($name, 'cyan'));
        try {
            runPhpMigration($db, $file, $name);

            $stmt = $db->prepare("INSERT INTO `migrations` (`migration`, `batch`) VALUES (?, ?)");
            $stmt->execute([$name, $batch]);
            success("Migrated:  " . color($name, 'cyan'));
            $ran++;
        } catch (PDOException $e) {
            error("Failed to migrate {$name}: " . $e->getMessage());
            return;
        }
    }

    if ($ran === 0) {
        info("Nothing to migrate. All migrations are up to date.");
    } else {
        line();
        success("Ran {$ran} migration(s).");
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: migrate:fresh
// ─────────────────────────────────────────────────────────────────────────────
function cmd_migrate_fresh(array $args): void {
    $db = resolveDb();
    if (!$db) {
        return;
    }

    info("Dropping all tables...");

    $db->exec("SET FOREIGN_KEY_CHECKS = 0");
    $stmt = $db->query("SHOW TABLES");
    $tables = $stmt->fetchAll(PDO::FETCH_COLUMN);
    foreach ($tables as $table) {
        $db->exec("DROP TABLE IF EXISTS `{$table}`");
        line("  Dropped: {$table}");
    }
    $db->exec("SET FOREIGN_KEY_CHECKS = 1");
    success("All tables dropped.");
    line();

    cmd_migrate($args);
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: migrate:status
// ─────────────────────────────────────────────────────────────────────────────
function cmd_migrate_status(array $args): void {
    $db = resolveDb();
    if (!$db) {
        return;
    }

    ensureMigrationsTable($db);
    $executed = getExecutedMigrations($db);
    $files = getMigrationFiles();

    if (empty($files)) {
        info("No migration files found.");
        return;
    }

    echo "\n";
    $header = sprintf("  %-6s %-50s %s", "Ran?", "Migration", "Status");
    echo color($header, 'gray') . "\n";
    echo "  " . str_repeat('─', 70) . "\n";

    foreach ($files as $file) {
        $name = pathinfo($file, PATHINFO_FILENAME);
        $ran = in_array($name, $executed, true);
        $status = $ran ? color('Yes', 'green') : color('No ', 'yellow');
        $label = $ran ? color('Migrated', 'green') : color('Pending ', 'yellow');
        printf("  %-15s %-50s %s\n", $status, $name, $label);
    }
    echo "\n";
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: migrate:rollback
// ─────────────────────────────────────────────────────────────────────────────
function cmd_migrate_rollback(array $args): void {
    $db = resolveDb();
    if (!$db) {
        return;
    }

    ensureMigrationsTable($db);

    $stmt = $db->query("SELECT COALESCE(MAX(`batch`), 0) FROM `migrations`");
    $maxBatch = (int) $stmt->fetchColumn();
    if ($maxBatch === 0) {
        info("Nothing to rollback.");
        return;
    }

    $stmt = $db->prepare("SELECT `migration` FROM `migrations` WHERE `batch` = ? ORDER BY `id` DESC");
    $stmt->execute([$maxBatch]);
    $entries = $stmt->fetchAll(PDO::FETCH_COLUMN);

    foreach ($entries as $entry) {
        $file = BASE_PATH . "/database/migrations/{$entry}.php";
        if (!file_exists($file)) {
            warn("Migration file not found: {$entry}.php. Skipping.");
            continue;
        }

        info("Rolling back: " . color($entry, 'cyan'));
        try {
            require $file;
            $class = migrationFileToClass($file);
            $migration = new $class();

            $sql = $migration->down();
            $statements = is_array($sql) ? $sql : [$sql];
            foreach ($statements as $statement) {
                $statement = trim($statement);
                if ($statement !== '') {
                    $db->exec($statement);
                }
            }

            $del = $db->prepare("DELETE FROM `migrations` WHERE `migration` = ? AND `batch` = ?");
            $del->execute([$entry, $maxBatch]);
            success("Rolled back: " . color($entry, 'cyan'));
        } catch (PDOException $e) {
            error("Failed to rollback {$entry}: " . $e->getMessage());
            return;
        }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: migrate:reset
// ─────────────────────────────────────────────────────────────────────────────
function cmd_migrate_reset(array $args): void {
    $db = resolveDb();
    if (!$db) {
        return;
    }
    $stmt = $db->query("SELECT COALESCE(MAX(`batch`), 0) FROM `migrations`");
    while ((int) $stmt->fetchColumn() > 0) {
        cmd_migrate_rollback($args);
        $stmt = $db->query("SELECT COALESCE(MAX(`batch`), 0) FROM `migrations`");
    }
    success("All migrations have been rolled back.");
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: migrate:refresh
// ─────────────────────────────────────────────────────────────────────────────
function cmd_migrate_refresh(array $args): void {
    cmd_migrate_reset($args);
    line();
    cmd_migrate($args);
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: db:seed
// ─────────────────────────────────────────────────────────────────────────────
function cmd_db_seed(array $args): void {
    $class = getOption($args, 'class', '');

    $seedsPath = BASE_PATH . '/database/seeds';
    if (!is_dir($seedsPath)) {
        error("Seeds directory not found.");
        return;
    }

    $db = resolveDb();
    if (!$db) {
        return;
    }

    if ($class !== '') {
        $file = $seedsPath . '/' . $class . '.php';
        if (!file_exists($file)) {
            error("Seeder file not found: {$class}.php");
            return;
        }
        require $file;
        $fqcn = "Database\\Seeds\\{$class}";
        $seeder = match ($class) {
            'MenuSeeder' => new $fqcn($db, new \App\Services\FileUploadService(BASE_PATH . '/storage/uploads')),
            default      => new $fqcn($db),
        };
        info("Seeding: " . color($class, 'cyan'));
        $seeder->run();
        success("Seeded:  " . color($class, 'cyan'));
    } else {
        // Run DatabaseSeeder (in-process, no exec)
        require $seedsPath . '/DatabaseSeeder.php';
        require $seedsPath . '/AdminSeeder.php';
        require $seedsPath . '/MenuSeeder.php';
        require $seedsPath . '/OrderSeeder.php';

        $seeder = new \Database\Seeds\DatabaseSeeder(
            new \Database\Seeds\AdminSeeder($db),
            new \Database\Seeds\MenuSeeder($db, new \App\Services\FileUploadService(BASE_PATH . '/storage/uploads')),
            new \Database\Seeds\OrderSeeder($db),
        );
        $seeder->run();
    }
    line();
    success("Database seeding completed.");
}

