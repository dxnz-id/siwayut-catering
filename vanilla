// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: make:migration
// ─────────────────────────────────────────────────────────────────────────────
function cmd_make_migration(array $args): void {
    $name = getArgument($args, 0);
    if ($name === '') {
        error("Please provide a migration name.");
        line("  Usage: php vanilla make:migration create_products_table");
        return;
    }

    $dir = BASE_PATH . '/database/migrations';
    if (!is_dir($dir)) {
        mkdir($dir, 0755, true);
    }

    $existing = glob($dir . '/*.php');
    $maxSeq = 0;
    foreach ($existing as $f) {
        $base = basename($f);
        if (preg_match('/^(\d+)_/', $base, $m)) {
            $maxSeq = max($maxSeq, (int) $m[1]);
        }
    }
    $seq = str_pad((string) ($maxSeq + 1), 3, '0', STR_PAD_LEFT);
    $filename = "{$seq}_{$name}.php";
    $path = $dir . '/' . $filename;

    $className = str_replace(' ', '', ucwords(str_replace('_', ' ', $name)));

    $table = '';
    if (preg_match('/create_(\w+)_table/', $name, $m)) {
        $table = $m[1];
    }

    if ($table) {
        $down = "DROP TABLE IF EXISTS `{$table}`";
        $up = "CREATE TABLE IF NOT EXISTS `{$table}` (
    `id` INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    `created_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    `updated_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci";
    } else {
        $up = '-- customize: write UP migration';
        $down = '-- customize: write DOWN migration';
    }

    $content = <<<PHP
<?php
declare(strict_types=1);

namespace Database\Migrations;

use App\Core\BaseMigration;

class {$className} extends BaseMigration {
    protected string \$filename = '{$seq}_{$name}';

    public function up(): string {
        return "{$up}";
    }

    public function down(): string {
        return "{$down}";
    }
}
PHP;

    file_put_contents($path, $content . "\n");
    success("Migration created: " . color("database/migrations/{$filename}", 'cyan'));
}

