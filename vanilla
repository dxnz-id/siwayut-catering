// ANSI Colors
// ─────────────────────────────────────────────────────────────────────────────
function color(string $text, string $color): string {
    $colors = [
        'green'   => "\033[32m",
        'red'     => "\033[31m",
        'yellow'  => "\033[33m",
        'blue'    => "\033[34m",
        'cyan'    => "\033[36m",
        'magenta' => "\033[35m",
        'white'   => "\033[97m",
        'gray'    => "\033[90m",
        'bold'    => "\033[1m",
        'reset'   => "\033[0m",
    ];
    return ($colors[$color] ?? '') . $text . "\033[0m";
}

function info(string $msg): void    { echo color('  INFO  ', 'green') . "  {$msg}\n"; }
function success(string $msg): void { echo color('  DONE  ', 'green') . "  {$msg}\n"; }
function warn(string $msg): void    { echo color('  WARN  ', 'yellow') . "  {$msg}\n"; }
function error(string $msg): void   { echo color('  ERROR ', 'red') . "  {$msg}\n"; }
function line(string $msg = ''): void { echo "  {$msg}\n"; }

