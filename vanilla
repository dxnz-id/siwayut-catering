function dbConfigured(): bool {
    return !empty($_ENV['DB_DATABASE'] ?? '');
}

function confirm(string $prompt): bool {
    if (!stream_isatty(STDIN)) {
        return false;
    }
    echo color('  CONFIRM ', 'yellow') . "  {$prompt} [y/N] ";
    $input = strtolower(trim(readline()));
    return in_array($input, ['y', 'yes'], true);
}

function isUnknownDatabaseError(PDOException $e): bool {
    $code = $e->errorInfo[1] ?? 0;
    return $code === 1049;
}

function resolveDb(): ?PDO {
    try {
        return getDb();
    } catch (PDOException $e) {
        $dbName = $_ENV['DB_DATABASE'] ?? '';
        if ($dbName !== '' && isUnknownDatabaseError($e) && confirm("Database '" . $dbName . "' doesn't exist. Create it now?")) {
            cmd_db_create();
            return getDb();
        }
        error("Database connection failed: " . $e->getMessage());
        return null;
    }
}

